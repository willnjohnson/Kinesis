{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Genesis",
  "version": "0.1.7",
  "identifier": "genesisapp",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Genesis v0.1.7",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons-genesis/32x32.png",
      "icons-genesis/128x128.png",
      "icons-genesis/128x128@2x.png",
      "icons-genesis/icon.icns",
      "icons-genesis/icon.ico"
    ],
    "resources": []
  }
}